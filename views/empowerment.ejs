<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Empowerment Bridge | HomeBridge Africa</title>

  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <%- include('partials/navbar') %>

  <!-- HERO SECTION -->
  <section class="empowerment-hero">
    <div class="container">

      <h1>Empowerment Bridge</h1>

      <p class="hero-subtitle">
        Connecting Africans across the globe through opportunities,
        mentorship, innovation, entrepreneurship, and impactful partnerships.
      </p>

      <a href="/contact" class="btn">
        Join the Network
      </a>

    </div>
  </section>

  <!-- INTRO -->
  <section class="section">
    <div class="container">

      <h2>Building Bridges Beyond Borders</h2>

      <p>
        The Empowerment Bridge creates meaningful connections between
        Africans in the diaspora and local communities. Through networking,
        mentorship, business collaborations, and knowledge sharing, we help
        individuals and organizations unlock opportunities for growth and impact.
      </p>

    </div>
  </section>

  <!-- FEATURES -->
  <section class="section light-bg">
    <div class="container">

      <h2>What We Offer</h2>

      <div class="cards">

        <div class="card">
          <img src="/images/networking.jpg" alt="Networking">
          <h3>Strategic Networking</h3>
          <p>
            Connect with professionals, entrepreneurs, investors,
            and changemakers from around the world.
          </p>
        </div>

        <div class="card">
          <img src="/images/mentorship.jpg" alt="Mentorship">
          <h3>Mentorship Programs</h3>
          <p>
            Gain guidance from experienced professionals and industry leaders.
          </p>
        </div>

        <div class="card">
          <img src="/images/business.jpg" alt="Business Growth">
          <h3>Business Development</h3>
          <p>
            Discover opportunities for partnerships, investment,
            and entrepreneurial growth.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- EVENTS -->
  <section class="section">
    <div class="container">

      <h2>Upcoming Opportunities</h2>

      <div class="cards">

        <div class="card">
          <h3>Leadership Summit</h3>
          <p>
            Engage with emerging leaders shaping Africa's future.
          </p>
        </div>

        <div class="card">
          <h3>Entrepreneurship Forum</h3>
          <p>
            Explore innovative business ideas and investment opportunities.
          </p>
        </div>

        <div class="card">
          <h3>Diaspora Networking Conference</h3>
          <p>
            Build lasting connections with Africans across the globe.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- IMPACT -->
  <section class="section light-bg">
    <div class="container">

      <h2>Our Vision</h2>

      <p>
        To create a thriving global community where Africans everywhere
        can collaborate, invest, mentor, and contribute to sustainable
        development across the continent.
      </p>

    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">

      <h2>Become Part of the Movement</h2>

      <p>
        Join a growing network of professionals, entrepreneurs,
        students, and leaders working together to build Africa's future.
      </p>

      <a href="/contact" class="btn">
        Get Involved
      </a>

    </div>
  </section>

<!-- FEATURED PAST EVENT -->
<section class="section light-bg">
  <div class="container">

    <h2>Featured Past Event</h2>

    <div class="event-showcase">

      <div class="event-image">
        <img src="/images/conference1.jpeg"
             alt="A Journey from Cape Coast to Ghana's Independence Flyer">
      </div>

      <div class="event-details">

        <h3>
          A Journey from Cape Coast to Ghana's Independence:
          From Shackles to Independence
        </h3>

        <p>
          This flagship event explored Ghana's historical journey from the
          era of the transatlantic slave trade to the achievement of
          independence. Participants engaged with powerful stories,
          historical reflections, and discussions on heritage, identity,
          resilience, and nation-building.
        </p>

        <p>
          Through this experience, attendees gained a deeper understanding
          of Ghana's role in African history and the significance of
          preserving our collective heritage for future generations.
        </p>

      </div>

    </div>

  </div>
</section>

<script>
  const hamburger = document.getElementById("hamburger");
  const navLinks = document.getElementById("navLinks");

  hamburger.addEventListener("click", () => {
    navLinks.classList.toggle("active");
  });
</script>
</body>
</html>