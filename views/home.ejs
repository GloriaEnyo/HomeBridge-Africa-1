<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Homebridge Africa</title>

  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('partials/navbar') %>

  <div class="scroll-progress"></div>

  <!-- ================= HERO ================= -->
  <section class="hero fade-in">
    <div class="hero-content">
      <h1>Experience Ghana Like Never Before</h1>

      <p>
        Homebridge Africa connects you to cultural immersion,
        internships, volunteering, and transformative experiences
        across Ghana.
      </p>

      <div class="hero-buttons">
        <a href="/about" class="btn primary-btn">Get Started</a>
        <a href="/programs" class="btn secondary-btn">Explore Programs</a>
      </div>
    </div>
  </section>

  <!-- ================= SERVICES ================= -->
  <section class="services fade-in">
    <h2 class="section-title">What We Offer</h2>

    <p class="section-subtitle">
      Meaningful programs designed to connect you with Ghana's culture and communities.
    </p>

    <div class="services-grid">

      <div class="service-card">
        <h3>Cultural Immersion</h3>
        <p>
          Live, learn, and experience authentic Ghanaian traditions and daily life.
        </p>
      </div>

      <div class="service-card">
        <h3>Internship Programs</h3>
        <p>
          Gain hands-on professional experience while contributing to real projects.
        </p>
      </div>

      <div class="service-card">
        <h3>Volunteer Opportunities</h3>
        <p>
          Support local communities through impactful service initiatives.
        </p>
      </div>

    </div>
  </section>

  <!-- ================= STATS ================= -->
  <section class="stats fade-in">

    <div class="stat">
      <h2 class="counter" data-target="1200">0</h2>
      <p>Visitors Hosted</p>
    </div>

    <div class="stat">
      <h2 class="counter" data-target="85">0</h2>
      <p>Community Projects</p>
    </div>

    <div class="stat">
      <h2 class="counter" data-target="40">0</h2>
      <p>Partner Organizations</p>
    </div>

  </section>

  <!-- ================= ABOUT GHANA ================= -->
  <section class="about-ghana fade-in">

    <div class="ghana-text">
      <h2>Discover Ghana</h2>

      <p>
        Ghana is one of Africa's most welcoming destinations,
        known for its rich cultural heritage, vibrant traditions,
        breathtaking landscapes, and friendly people.
      </p>

      <p>
        From historic castles and coastal beaches to lively
        markets and colorful festivals, Ghana offers unforgettable
        experiences for every visitor.
      </p>

      <p>
        At Homebridge Africa, we ensure every visitor connects
        deeply with the culture, people, and opportunities
        that make Ghana unique.
      </p>
    </div>

    <div class="ghana-images">
      <div class="img-box img1"></div>
      <div class="img-box img2"></div>
      <div class="img-box img3"></div>
      <div class="img-box img4"></div>
      <div class="img-box img5"></div>
    </div>

  </section>

  <!-- ================= WHY CHOOSE US ================= -->
  <section class="why-us fade-in">

    <h2 class="section-title">Why Choose HomeBridge Africa?</h2>

    <div class="why-grid">

      <div class="why-card">
        <h3>Authentic Experiences</h3>
        <p>
          Connect with local communities, traditions,
          and real Ghanaian culture.
        </p>
      </div>

      <div class="why-card">
        <h3>Safe & Reliable</h3>
        <p>
          Our team provides support and guidance
          throughout your entire journey.
        </p>
      </div>

      <div class="why-card">
        <h3>Life-Changing Impact</h3>
        <p>
          Build meaningful relationships while making
          a positive contribution.
        </p>
      </div>

    </div>

  </section>

  <!-- ================= DESTINATIONS ================= -->
  <section class="destinations fade-in">

    <h2 class="section-title">Featured Destinations</h2>

    <div class="destination-grid">

      <div class="destination-card">
        <img src="/images/cape-coast.jpg" alt="Cape Coast">
        <div class="destination-info">
          <h3>Cape Coast</h3>
          <p>History, culture, beaches and heritage.</p>
        </div>
      </div>

      <div class="destination-card">
        <img src="/images/kakum.jpg" alt="Kakum National Park">
        <div class="destination-info">
          <h3>Kakum National Park</h3>
          <p>Experience Ghana's famous canopy walkway.</p>
        </div>
      </div>

      <div class="destination-card">
        <img src="/images/volta.jpg" alt="Volta Region">
        <div class="destination-info">
          <h3>Volta Region</h3>
          <p>Waterfalls, mountains and natural beauty.</p>
        </div>
      </div>

    </div>

  </section>

  <!-- ================= TESTIMONIALS ================= -->
  <section class="testimonials fade-in">

    <h2 class="section-title">What Our Visitors Say</h2>

    <div class="testimonial-grid">

      <div class="testimonial-card">
        <p>
          "HomeBridge Africa gave me an unforgettable
          cultural experience. I felt welcomed from day one."
        </p>
        <h4>- Sarah, USA</h4>
      </div>

      <div class="testimonial-card">
        <p>
          "The internship opportunity helped me gain
          professional experience while exploring Ghana."
        </p>
        <h4>- Michael, UK</h4>
      </div>

      <div class="testimonial-card">
        <p>
          "Professional, friendly and highly organized.
          I would definitely return."
        </p>
        <h4>- Linda, Canada</h4>
      </div>

    </div>

  </section>

  <!-- ================= PARTNERS ================= -->
  <section class="partners fade-in">

    <h2 class="section-title">Our Partners</h2>

    <div class="partner-logos">

      <div class="partner-logo">University Partners</div>
      <div class="partner-logo">NGO Partners</div>
      <div class="partner-logo">Community Leaders</div>
      <div class="partner-logo">Corporate Partners</div>

    </div>

  </section>

  <!-- ================= NEWSLETTER ================= -->
  <section class="newsletter fade-in">

    <h2>Stay Connected</h2>

    <p>
      Subscribe for updates on cultural immersion,
      internships, volunteering opportunities,
      and upcoming events.
    </p>

    <form class="newsletter-form">

      <input
        type="email"
        placeholder="Enter your email address"
        required
      >

      <button type="submit">
        Subscribe
      </button>

    </form>

  </section>

  <!-- ================= CTA ================= -->
  <section class="cta fade-in">

    <h2>Your Ghana Journey Starts Here</h2>

    <p>
      Join travelers, students, volunteers, and professionals
      discovering Ghana through authentic experiences.
    </p>

    <div class="hero-buttons">
      <a href="/contact" class="btn primary-btn">
        Contact Us
      </a>

      <a href="/programs" class="btn secondary-btn">
        Explore Programs
      </a>
    </div>

  </section>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>

</body>
</html>