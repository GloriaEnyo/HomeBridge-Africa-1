<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Immersion Experience | Homebridge Africa</title>

  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('partials/navbar') %>

  <!-- HERO SECTION -->
  <section class="immersion-hero fade-in">

    <div class="immersion-overlay"></div>

    <div class="immersion-hero-content">

      <h1>Experience Ghana Beyond Tourism</h1>

      <p>
        Discover authentic Ghanaian culture through community engagement,
        heritage exploration, local traditions, and transformative experiences.
      </p>

      <div class="hero-buttons">
        <a href="/contact" class="btn primary-btn">
          Join a Program
        </a>

        <a href="/gallery" class="btn secondary-btn">
          View Gallery
        </a>
      </div>

    </div>

  </section>

  <!-- INTRO SECTION -->
  <section class="immersion-intro fade-in">

    <div class="container">

      <div class="intro-text">

        <h2>The Immersion Experience</h2>

        <p>
          Homebridge Africa’s immersion programs are designed to help participants
          build genuine cultural connections while experiencing the beauty,
          traditions, and everyday life of Ghana.
        </p>

        <p>
          Whether you are seeking cultural reconnection, educational exploration,
          volunteer experiences, or meaningful travel, our programs provide
          unforgettable moments that inspire growth and global understanding.
        </p>

      </div>

    </div>

  </section>

  <!-- IMMERSION PATHS -->
  <section class="immersion-paths fade-in">

    <div class="container">

      <h2 class="section-title">Choose Your Path</h2>

      <div class="paths-grid">

        <!-- PATH A -->
        <div class="path-card">

          <div class="path-icon">🏡</div>

          <h3>Path A: Kinship & Impact Residency</h3>

          <p>
            Live with a carefully selected Ghanaian host family for
            2–24 weeks while participating in meaningful community projects
            and authentic cultural experiences.
          </p>

          <ul>
            <li>Host family living experience</li>
            <li>Community engagement projects</li>
            <li>Cultural mentorship</li>
            <li>Daily local experiences</li>
          </ul>

        </div>

        <!-- PATH B -->
        <div class="path-card">

          <div class="path-icon">🌍</div>

          <h3>Path B: Curated Heritage Immersions</h3>

          <p>
            Personalized cultural journeys for families, students,
            and groups seeking immersive experiences across Ghana.
          </p>

          <ul>
            <li>Historical site visits</li>
            <li>Cultural workshops</li>
            <li>Traditional festivals</li>
            <li>Guided heritage tours</li>
          </ul>

        </div>

      </div>

    </div>

  </section>
<section class="experience-section fade-in">

  <div class="container">

    <h2 class="section-title">What You’ll Experience</h2>

    <div class="experience-grid">

      <div class="experience-card">
        <img src="/images/image1.jpg" alt="Festivals">
        <h3>Traditional Festivals</h3>
        <p>Participate in vibrant celebrations and cultural ceremonies.</p>
      </div>

      <div class="experience-card">
        <img src="/images/image3.jpg" alt="Food">
        <h3>Local Cuisine</h3>
        <p>Experience authentic Ghanaian dishes and cooking traditions.</p>
      </div>

      <div class="experience-card">
        <img src="/images/image3.jpg" alt="Community">
        <h3>Community Connection</h3>
        <p>Engage with local families and community projects.</p>
      </div>

      <div class="experience-card">
        <img src="/images/image4.jpg" alt="History">
        <h3>Historical Exploration</h3>
        <p>Visit castles, museums, and heritage landmarks across Ghana.</p>
      </div>

    </div>

  </div>

</section>
      

  <!-- IMAGE SHOWCASE -->
  <section class="immersion-gallery fade-in">

    <div class="container">

      <h2 class="section-title">Moments From Our Experiences</h2>

      <div class="immersion-gallery-grid">

        <div class="gallery-box img1"></div>
        <div class="gallery-box img2"></div>
        <div class="gallery-box img3"></div>
        <div class="gallery-box img4"></div>
        <div class="gallery-box img5"></div>
        <div class="gallery-box img6"></div>

      </div>

    </div>

  </section>

  <!-- WHY GHANA -->
  <section class="why-ghana fade-in">

    <div class="container">

      <h2 class="section-title">Why Ghana?</h2>

      <div class="why-grid">

        <div class="why-card">
          <h3>Peace & Hospitality</h3>

          <p>
            Ghana is widely known for its welcoming people,
            peaceful environment, and vibrant communities.
          </p>
        </div>

        <div class="why-card">
          <h3>Rich Cultural Heritage</h3>

          <p>
            Experience diverse traditions, music, dance,
            storytelling, and local customs.
          </p>
        </div>

        <div class="why-card">
          <h3>Life-Changing Experiences</h3>

          <p>
            Leave with meaningful memories, global perspectives,
            and authentic human connections.
          </p>
        </div>

      </div>

    </div>

  </section>

  <!-- CTA SECTION -->
  <section class="cta fade-in">

    <div class="container">

      <h2>Ready To Begin Your Journey?</h2>

      <p>
        Join Homebridge Africa and experience Ghana in a meaningful and unforgettable way.
      </p>

      <a href="/contact" class="btn primary-btn">
        Contact Us
      </a>

    </div>

  </section>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>

  <script>
  const hamburger = document.getElementById("hamburger");
  const navLinks = document.getElementById("navLinks");

  hamburger.addEventListener("click", () => {
    navLinks.classList.toggle("active");
  });
</script>

</body>
</html>