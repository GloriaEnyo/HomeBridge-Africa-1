<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>About Us | HomeBridge Africa</title>

  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar') %>

<!-- HERO -->
<section class="about-hero">

  <div class="about-hero-content">

    <h1>Connecting People to the Heart of Ghana</h1>

    <p>
      HomeBridge Africa creates meaningful experiences through cultural
      immersion, internships, volunteering opportunities, and community engagement.
    </p>

  </div>

</section>

<!-- OUR STORY -->
<section class="our-story">

  <div class="story-content">

    <h2>Our Story</h2>

    <p>
      HomeBridge Africa was founded with a simple vision:
      to help people experience Ghana beyond tourism.
    </p>

    <p>
      We believe the most memorable journeys happen when visitors connect
      with communities, learn from local cultures, and contribute to meaningful initiatives.
    </p>

    <p>
      Through carefully designed programs, we create opportunities for
      cultural exchange, personal growth, and lasting impact.
    </p>

  </div>

</section>

<!-- MISSION VISION VALUES -->
<section class="mvv">

  <div class="mvv-card">
    <h3>Our Mission</h3>
    <p>
      To create transformative experiences that connect people with Ghana’s culture,
      communities, and opportunities.
    </p>
  </div>

  <div class="mvv-card">
    <h3>Our Vision</h3>
    <p>
      To become Africa's leading platform for cultural immersion,
      volunteering, and international exchange.
    </p>
  </div>

  <div class="mvv-card">
    <h3>Our Values</h3>
    <p>
      Authenticity, Excellence, Community, Respect, and Impact.
    </p>
  </div>

</section>

<!-- WHY WE EXIST -->
<section class="why-exist">

  <h2>Why We Exist</h2>

  <p>
    Many travelers only see a small part of Ghana.
    We help visitors experience the real Ghana through meaningful
    interactions, professional opportunities, and community engagement.
  </p>

</section>

<!-- WHAT MAKES US DIFFERENT -->
<section class="difference">

  <h2>What Makes Us Different?</h2>

  <div class="difference-grid">

    <div class="difference-card">
      <h3>Local Expertise</h3>
      <p>
        We understand Ghana's culture and communities firsthand.
      </p>
    </div>

    <div class="difference-card">
      <h3>Personalized Experiences</h3>
      <p>
        Programs tailored to individual interests and goals.
      </p>
    </div>

    <div class="difference-card">
      <h3>Meaningful Impact</h3>
      <p>
        Every experience is designed to benefit both visitors and communities.
      </p>
    </div>

  </div>

</section>

<!-- TEAM -->
<section class="team">

  <h2>Meet Our Team</h2>

  <div class="team-grid">

    <div class="team-card">
      <img src="/images/team1.jpg" alt="Team Member">
      <h3>Founder & Director</h3>
      <p>Leadership and Strategic Partnerships</p>
    </div>

    <div class="team-card">
      <img src="/images/team2.jpg" alt="Team Member">
      <h3>Programs Coordinator</h3>
      <p>Managing Visitor Experiences</p>
    </div>

    <div class="team-card">
      <img src="/images/team3.jpg" alt="Team Member">
      <h3>Community Relations</h3>
      <p>Building Local Connections</p>
    </div>

  </div>

</section>

<!-- IMPACT -->
<section class="impact">

  <h2>Our Impact</h2>

  <div class="impact-grid">

    <div class="impact-box">
      <h3>1200+</h3>
      <p>Visitors Hosted</p>
    </div>

    <div class="impact-box">
      <h3>85+</h3>
      <p>Projects Supported</p>
    </div>

    <div class="impact-box">
      <h3>40+</h3>
      <p>Partners</p>
    </div>

  </div>

</section>

<!-- CTA -->
<section class="about-cta">

  <h2>Become Part of the Experience</h2>

  <p>
    Discover Ghana through authentic connections,
    meaningful opportunities, and unforgettable experiences.
  </p>

  <a href="/contact" class="btn primary-btn">
    Contact Us
  </a>

</section>

<%- include('partials/footer') %>

</body>
</html>